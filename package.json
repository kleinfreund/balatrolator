{
	"name": "balatrolator",
	"version": "1.0.1o",
	"license": "MIT",
	"description": "Balatrolator, a Balatro calculator",
	"author": {
		"name": "Philipp Rudloff",
		"url": "https://kleinfreund.de"
	},
	"homepage": "https://balatrolator.com",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kleinfreund/balatrolator.git"
	},
	"bugs": {
		"url": "https://github.com/kleinfreund/balatrolator/issues"
	},
	"keywords": [
		"Balatro",
		"score",
		"calculator"
	],
	"type": "module",
	"imports": {
		"#*": "./src/*"
	},
	"scripts": {
		"start": "vite",
		"test:node": "vitest run",
		"test:node:watch": "vitest watch",
		"test:browser": "playwright test",
		"test:browser:ui": "playwright test --ui",
		"lint": "run-p lint:*",
		"lint:code-quality": "eslint",
		"lint:lockfile": "lockfile-lint --path package-lock.json --validate-hosts --allowed-hosts npm",
		"lint:types": "tsc --noEmit",
		"lint:knip": "knip",
		"fix": "run-p fix:*",
		"fix:code-quality": "npm run lint:code-quality -- --fix",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "husky"
	},
	"devEngines": {
		"runtime": {
			"name": "node",
			"version": "^24.14.1"
		},
		"packageManager": {
			"name": "npm",
			"version": "^11.12.1"
		}
	},
	"dependencies": {
		"decimal.js": "10.6.0",
		"lit-html": "3.3.2"
	},
	"devDependencies": {
		"@commitlint/cli": "20.5.0",
		"@commitlint/config-conventional": "20.5.0",
		"@commitlint/types": "20.5.0",
		"@eslint/js": "10.0.1",
		"@playwright/test": "1.58.2",
		"@stylistic/eslint-plugin": "5.10.0",
		"@types/node": "25.5.0",
		"@vitest/coverage-v8": "4.1.2",
		"eslint": "10.1.0",
		"eslint-plugin-playwright": "2.10.1",
		"globals": "17.4.0",
		"husky": "9.1.7",
		"jsdom": "29.0.1",
		"knip": "6.1.1",
		"lockfile-lint": "5.0.0",
		"npm-run-all2": "8.0.4",
		"playwright": "1.58.2",
		"typescript": "5.9.3",
		"typescript-eslint": "8.58.0",
		"vite": "8.0.3",
		"vitest": "4.1.2"
	}
}
