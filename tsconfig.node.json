{
	"include": [
		"balatrolator.ts",
		"vite.config.*",
		"playwright.config.*",
		"eslint.config.*",
		"playwright/**/*"
	],
	"compilerOptions": {
		"tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
		"lib": [
			"ES2024"
		],
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"allowImportingTsExtensions": true,
		"esModuleInterop": true,
		"verbatimModuleSyntax": true,
		"noEmit": true,
		"skipLibCheck": true,
		"target": "es2024",
		"strict": true,
		"erasableSyntaxOnly": true,
		"types": ["node"]
	}
}
